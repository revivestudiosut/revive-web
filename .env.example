# This documents every variable the project uses and where each one belongs.
# You do NOT edit this file. To set up your machine, you only need to create
# one file: .env.local (see the first section below).

# ─────────────────────────────────────────────────────────────────────────
# .env.local  (gitignored, CREATE THIS: it holds your personal deploy token)
# ─────────────────────────────────────────────────────────────────────────
# Get a token (or ask Trent) at https://dash.cloudflare.com/profile/api-tokens
# Create Token -> permission "Cloudflare Pages: Edit".
CLOUDFLARE_API_TOKEN=your-cloudflare-pages-edit-token

# ─────────────────────────────────────────────────────────────────────────
# .env  (already committed, listed here for reference, no secrets)
# ─────────────────────────────────────────────────────────────────────────
PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
CONTACT_TO_EMAIL=revivestudiosut@gmail.com
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id   # not secret

# ─────────────────────────────────────────────────────────────────────────
# Runtime secrets: set these in the Cloudflare dashboard, NOT locally.
# (Workers & Pages -> revive-web -> Settings -> Environment variables)
# They power the contact form at runtime; you do not need them to deploy.
# ─────────────────────────────────────────────────────────────────────────
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=your-from-address
