# Copy this to .env.dev, .env.staging, or .env.production
# and fill in real values. These files are gitignored.

# Turnstile (Cloudflare dashboard → Security → Turnstile)
PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Resend (resend.com → API Keys)
RESEND_API_KEY=your-resend-api-key

# Destination email for contact form submissions
CONTACT_TO_EMAIL=revivestudiosut@gmail.com
