        </h4>
        <div class="flex flex-col gap-3">
          <a href="/" class="text-sm text-white/60 transition-colors hover:text-white">Home</a>
          <a href="/about" class="text-sm text-white/60 transition-colors hover:text-white">About</a>
          <a href="/services" class="text-sm text-white/60 transition-colors hover:text-white">Services</a>
          <a href="/portfolio" class="text-sm text-white/60 transition-colors hover:text-white">Portfolio</a>
          <a href="/contact" class="text-sm text-white/60 transition-colors hover:text-white">Contact</a>
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="mb-4 text-xs font-sans font-medium uppercase tracking-[0.15em] text-white">
          Contact
        </h4>
        <div class="flex flex-col gap-3 text-sm text-white/60">
          <a href="mailto:revivestudiosut@gmail.com" class="transition-colors hover:text-white">
            revivestudiosut@gmail.com
          </a>
          <a href="tel:+13852670359" class="transition-colors hover:text-white">
            (385) 267-0359
          </a>
          <a href="tel:+18012448871" class="transition-colors hover:text-white">
            (801) 244-8871
          </a>
          <p>Mon–Fri, 9AM–6PM MST</p>
        </div>
      </div>
    </div>

    <div class="mt-12 border-t border-white/10 pt-8 text-center text-xs text-white/40">
      <p>&copy; {new Date().getFullYear()} Revive Studios. All rights reserved.</p>
    </div>
  </div>
</footer>
