<footer class="bg-charcoal text-white/80">
  <div class="mx-auto max-w-7xl px-6 py-16 md:px-12">
    <div class="grid gap-12 md:grid-cols-3">
      <!-- Brand -->
      <div>
        <img
          src="/images/logo-white.png"
          alt="Revive Studios"
          class="mb-6 h-12 w-auto"
        />
        <p class="text-sm leading-relaxed text-white/60">
          Creating homes that feel effortlessly beautiful, deeply personal, and
          designed for real life.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="mb-4 text-xs font-sans font-medium uppercase tracking-[0.15em] text-white">
