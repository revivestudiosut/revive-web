---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Revive Studios">
  <!-- Page Header -->
  <section class="px-6 pb-12 pt-28 md:px-12 md:pb-16 md:pt-36">
    <div class="mx-auto max-w-7xl text-center">
      <h1 class="mb-6 font-serif text-5xl font-light text-charcoal md:text-6xl">
        Get in Touch
      </h1>
      <p class="text-lg text-charcoal-light">
        Ready to transform your space? We'd love to hear from you.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="px-6 pb-20 md:px-12 md:pb-28">
    <div class="mx-auto grid max-w-5xl gap-16 md:grid-cols-2">
      <!-- Contact Details -->
      <div>
        <h2 class="mb-8 font-serif text-3xl font-light text-charcoal">
          Contact Details
        </h2>
        <div class="space-y-6">
          <div>
            <h3 class="mb-1 text-xs font-sans font-medium uppercase tracking-[0.15em] text-olive">
              Email
            </h3>
            <a
              href="mailto:revivestudiosut@gmail.com"
              class="text-lg text-charcoal transition-colors hover:text-olive"
            >
              revivestudiosut@gmail.com
            </a>
          </div>
          <div>
            <h3 class="mb-1 text-xs font-sans font-medium uppercase tracking-[0.15em] text-olive">
              Phone
            </h3>
            <div class="space-y-1">
              <a
                href="tel:+13852670359"
                class="block text-lg text-charcoal transition-colors hover:text-olive"
              >
                (385) 267-0359
              </a>
              <a
                href="tel:+18012448871"
                class="block text-lg text-charcoal transition-colors hover:text-olive"
              >
                (801) 244-8871
              </a>
            </div>
          </div>
          <div>
            <h3 class="mb-1 text-xs font-sans font-medium uppercase tracking-[0.15em] text-olive">
              Hours
            </h3>
            <p class="text-lg text-charcoal">Mon–Fri, 9AM–6PM MST</p>
          </div>
        </div>

        <!-- Photo accent -->
        <div class="mt-12 hidden md:block">
          <img
            src="/images/serenity-suite-bathroom.png"
            alt="Interior design by Revive Studios"
            class="aspect-[4/3] w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Contact Form -->
      <div>
        <h2 class="mb-8 font-serif text-3xl font-light text-charcoal">
          Send a Message
        </h2>
        <form
          action="https://formspree.io/f/placeholder"
          method="POST"
          class="space-y-6"
        >
          <div>
            <label for="name" class="mb-2 block text-xs font-sans font-medium uppercase tracking-[0.15em] text-charcoal-light">
              Name
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full border border-warm-gray bg-white px-4 py-3 text-charcoal outline-none transition-colors focus:border-olive"
            />
          </div>
          <div>
            <label for="email" class="mb-2 block text-xs font-sans font-medium uppercase tracking-[0.15em] text-charcoal-light">
              Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full border border-warm-gray bg-white px-4 py-3 text-charcoal outline-none transition-colors focus:border-olive"
            />
          </div>
          <div>
            <label for="phone" class="mb-2 block text-xs font-sans font-medium uppercase tracking-[0.15em] text-charcoal-light">
              Phone
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full border border-warm-gray bg-white px-4 py-3 text-charcoal outline-none transition-colors focus:border-olive"
            />
          </div>
          <div>
            <label for="message" class="mb-2 block text-xs font-sans font-medium uppercase tracking-[0.15em] text-charcoal-light">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full resize-none border border-warm-gray bg-white px-4 py-3 text-charcoal outline-none transition-colors focus:border-olive"
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full bg-olive px-8 py-3.5 text-xs font-sans font-medium uppercase tracking-[0.2em] text-white transition-colors hover:bg-olive-dark"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
