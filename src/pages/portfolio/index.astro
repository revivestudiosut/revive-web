---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../data/projects';

const featured = projects.find((p) => p.featured) || projects[0];
const otherProjects = projects.filter((p) => p.slug !== featured.slug);
---

<BaseLayout title="Portfolio — Revive Studios">
  <!-- Page Header -->
  <section class="px-6 pb-12 pt-28 md:px-12 md:pb-16 md:pt-36">
    <div class="mx-auto max-w-7xl">
      <h1 class="mb-6 font-serif text-5xl font-light text-charcoal md:text-6xl">
        Our Portfolio
      </h1>
      <p class="max-w-2xl text-lg text-charcoal-light">
        Explore our curated collection of thoughtfully designed spaces that
        blend minimalist aesthetics with warmth and functionality.
      </p>
    </div>
  </section>

  <!-- Featured Project -->
  <section class="px-6 pb-20 md:px-12 md:pb-28">
    <div class="mx-auto max-w-7xl">
      <a href={`/portfolio/${featured.slug}`} class="group block">
        <div class="relative overflow-hidden">
          <div class="aspect-[16/9] md:aspect-[21/9]">
            <img
              src={featured.hero}
              alt={featured.title}
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-8 md:p-12">
            <p class="mb-2 text-xs font-sans font-medium uppercase tracking-[0.15em] text-white/70">
              Featured Project
            </p>
            <h2 class="mb-2 font-serif text-3xl font-light text-white md:text-4xl">
              {featured.title}
            </h2>
            <p class="mb-4 text-sm text-white/70">{featured.location}</p>
            <p class="max-w-xl text-sm leading-relaxed text-white/80 md:text-base">
              {featured.description}
            </p>
            <span class="mt-6 inline-block border-b border-white/50 pb-0.5 text-xs font-sans font-medium uppercase tracking-[0.15em] text-white transition-colors group-hover:border-white">
              View Project
            </span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- All Projects Grid -->
  <section class="bg-cream-dark px-6 py-20 md:px-12 md:py-28">
    <div class="mx-auto max-w-7xl">
      <h2 class="mb-12 font-serif text-3xl font-light text-charcoal md:text-4xl">
        All Projects
      </h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {otherProjects.map((project) => (
          <a href={`/portfolio/${project.slug}`} class="group block">
            <div class="relative overflow-hidden">
              <div class="aspect-[4/3]">
                <img
                  src={project.hero}
                  alt={project.title}
                  class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="absolute inset-0 flex items-end bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100">
                <div class="p-6">
                  <span class="border-b border-white/50 pb-0.5 text-xs font-sans font-medium uppercase tracking-[0.15em] text-white">
                    View Project
                  </span>
                </div>
              </div>
            </div>
            <div class="mt-4">
              <h3 class="font-serif text-xl font-light text-charcoal">
                {project.title}
              </h3>
              <p class="text-sm text-charcoal-light">{project.location}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-olive px-6 py-20 md:px-12 md:py-28">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-4 font-serif text-4xl font-light text-white md:text-5xl">
        Love What You See?
      </h2>
      <p class="mb-8 text-lg text-white/80">
        Let's create something beautiful for your home.
      </p>
      <a
        href="/contact"
        class="inline-block border-2 border-white px-8 py-3.5 text-xs font-sans font-medium uppercase tracking-[0.2em] text-white transition-all hover:bg-white hover:text-olive"
      >
        Book a Consultation
      </a>
    </div>
  </section>
</BaseLayout>
