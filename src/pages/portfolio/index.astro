---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import JournalCard from '../../components/JournalCard.astro';

const projects = await getCollection('projects');
const featured = projects.find((p) => p.data.featured) || projects[0];

const nonFeatured = projects.filter((p) => p.id !== featured.id);
const sortedByRecency = [...nonFeatured].sort((a, b) => {
  const aDate = a.data.completedAt?.valueOf() ?? 0;
  const bDate = b.data.completedAt?.valueOf() ?? 0;
  if (aDate !== bDate) return bDate - aDate;
  return a.id.localeCompare(b.id);
});
const recentProjects = sortedByRecency.slice(0, 3);

const journalPosts = (await getCollection('journal')).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);
const recentJournal = journalPosts.slice(0, 3);
---

<BaseLayout title="Portfolio — Revive Studios">
  <!-- Page Header -->
  <section class="px-6 pb-12 pt-28 md:px-12 md:pb-16 md:pt-36">
    <div class="mx-auto max-w-7xl">
      <h1 class="mb-6 font-serif text-5xl font-light text-charcoal md:text-6xl">
        Our Portfolio
      </h1>
      <p class="max-w-2xl text-lg text-charcoal-light">
        We stay busy with active remodel jobs. Our work goes well beyond paint,
        furniture, and accessories. We focus on the architecture of the space,
        working directly with general contractors to make a home both usable
        and beautiful. We specialize in kitchens, bathrooms, mudrooms, and other
        high-traffic areas, making your home exactly what you need.
      </p>
    </div>
  </section>

  <!-- Featured Project -->
  <section class="px-6 pb-20 md:px-12 md:pb-28">
    <div class="mx-auto max-w-7xl">
      <a href={`/portfolio/${featured.id}`} class="group block">
        <div class="overflow-hidden">
          <div class="aspect-[16/9] md:aspect-[21/9]">
            <img
              src={featured.data.hero}
              alt={featured.data.title}
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
          </div>
        </div>
        <div class="mt-6">
          <p class="mb-2 text-xs font-sans font-medium uppercase tracking-[0.15em] text-olive">
            Featured Project
          </p>
          <h2 class="mb-2 font-serif text-3xl font-light text-charcoal md:text-4xl">
            {featured.data.title}
          </h2>
          <p class="mb-4 text-sm text-charcoal-light">{featured.data.location}</p>
          {featured.data.description && (
            <p class="max-w-xl text-sm leading-relaxed text-charcoal-light md:text-base">
              {featured.data.description}
            </p>
          )}
          <span class="mt-6 inline-block border-b border-charcoal/30 pb-0.5 text-xs font-sans font-medium uppercase tracking-[0.15em] text-charcoal transition-colors group-hover:border-charcoal">
            View Project
          </span>
        </div>
      </a>
    </div>
  </section>

  <!-- Recent Projects -->
  {recentProjects.length > 0 && (
    <section class="bg-cream-dark px-6 py-20 md:px-12 md:py-28">
      <div class="mx-auto max-w-7xl">
        <div class="mb-12 flex items-end justify-between gap-6">
          <div>
            <p class="mb-3 text-xs font-sans font-medium uppercase tracking-[0.15em] text-olive">
              What's Happening Now
            </p>
            <h2 class="font-serif text-3xl font-light text-charcoal md:text-4xl">
              Recent Projects
            </h2>
          </div>
          <a
            href="/portfolio/all"
            class="hidden text-xs font-sans font-medium uppercase tracking-[0.15em] text-charcoal transition-colors hover:text-olive sm:inline-block"
          >
            View All Projects &rarr;
          </a>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {recentProjects.map((project) => (
            <a href={`/portfolio/${project.id}`} class="group block">
              <div class="relative overflow-hidden">
                <div class="aspect-[4/3]">
                  <img
                    src={project.data.hero}
                    alt={project.data.title}
                    class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
                <div class="absolute inset-0 flex items-end bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100">
                  <div class="p-6">
                    <span class="border-b border-white/50 pb-0.5 text-xs font-sans font-medium uppercase tracking-[0.15em] text-white">
                      View Project
                    </span>
                  </div>
                </div>
              </div>
              <div class="mt-4">
                <h3 class="font-serif text-xl font-light text-charcoal">
                  {project.data.title}
                </h3>
                <p class="text-sm text-charcoal-light">{project.data.location}</p>
              </div>
            </a>
          ))}
        </div>
        <div class="mt-12 text-center sm:hidden">
          <a
            href="/portfolio/all"
            class="text-xs font-sans font-medium uppercase tracking-[0.15em] text-charcoal transition-colors hover:text-olive"
          >
            View All Projects &rarr;
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- From the Journal -->
  {recentJournal.length > 0 && (
    <section class="px-6 py-20 md:px-12 md:py-28">
      <div class="mx-auto max-w-7xl">
        <div class="mb-12 flex items-end justify-between gap-6">
          <div>
            <p class="mb-3 text-xs font-sans font-medium uppercase tracking-[0.15em] text-olive">
              From the Journal
            </p>
            <h2 class="font-serif text-3xl font-light text-charcoal md:text-4xl">
              Stories &amp; Techniques
            </h2>
          </div>
          <a
            href="/portfolio/journal"
            class="hidden text-xs font-sans font-medium uppercase tracking-[0.15em] text-charcoal transition-colors hover:text-olive sm:inline-block"
          >
            View All &rarr;
          </a>
        </div>
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {recentJournal.map((post) => <JournalCard post={post} />)}
        </div>
        <div class="mt-12 text-center sm:hidden">
          <a
            href="/portfolio/journal"
            class="text-xs font-sans font-medium uppercase tracking-[0.15em] text-charcoal transition-colors hover:text-olive"
          >
            View All &rarr;
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-olive px-6 py-20 md:px-12 md:py-28">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-4 font-serif text-4xl font-light text-white md:text-5xl">
        Love What You See?
      </h2>
      <p class="mb-8 text-lg text-white/80">
        Let's create something beautiful for your home.
      </p>
      <a
        href="/contact"
        class="inline-block border-2 border-white px-8 py-3.5 text-xs font-sans font-medium uppercase tracking-[0.2em] text-white transition-all hover:bg-white hover:text-olive"
      >
        Book a Consultation
      </a>
    </div>
  </section>
</BaseLayout>
