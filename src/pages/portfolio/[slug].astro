---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import JournalCard from '../../components/JournalCard.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project, index) => ({
    params: { slug: project.id },
    props: {
      project,
      prev: index > 0 ? projects[index - 1] : undefined,
      next: index < projects.length - 1 ? projects[index + 1] : undefined,
    },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
  prev?: CollectionEntry<'projects'>;
  next?: CollectionEntry<'projects'>;
}

const { project, prev, next } = Astro.props;
const { title, location, description, gallery } = project.data;
const { Content } = await render(project);
const hasBody = (project.body?.trim().length ?? 0) > 0;

const journalPosts = (await getCollection('journal'))
  .filter((post) => post.data.project?.id === project.id)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

// Precompute column distributions for flush-top flex masonry
const galleryWithIdx = gallery.map((img, i) => ({ img, i }));
const galleryCols2 = [0, 1].map(c => galleryWithIdx.filter(({ i }) => i % 2 === c));
const galleryCols3 = [0, 1, 2].map(c => galleryWithIdx.filter(({ i }) => i % 3 === c));
---

<BaseLayout title={`${title} | Revive Studios`}>
  <!-- Back Link + Header -->
  <section class="px-6 pb-8 pt-28 md:px-12 md:pb-12 md:pt-36">
    <div class="mx-auto max-w-7xl">
      <a
        href="/portfolio"
        class="mb-8 inline-flex items-center gap-2 text-sm text-charcoal-light transition-colors hover:text-olive"
      >
        <span>&larr;</span> Back to Portfolio
      </a>
      <h1 class="mb-3 font-serif text-4xl font-light text-charcoal md:text-5xl lg:text-6xl">
        {title}
      </h1>
      <p class="mb-6 text-sm uppercase tracking-[0.1em] text-olive">
        {location}
      </p>
      {description && (
        <p class="max-w-3xl text-lg leading-relaxed text-charcoal-light">
          {description}
        </p>
      )}
      {hasBody && (
        <div class="prose-journal mt-10 max-w-3xl font-sans text-base leading-relaxed text-charcoal">
          <Content />
        </div>
      )}
    </div>
  </section>

  <!-- Photo Gallery -->
  <section class="px-6 pb-20 md:px-12 md:pb-28">
    <div class="mx-auto max-w-7xl">
      <!-- Mobile: 1 column -->
      <div class="flex flex-col gap-3 sm:hidden">
        {gallery.map((image, i) => (
          <div class="overflow-hidden">
            <img
              src={image}
              alt={`${title}, Photo ${i + 1}`}
              class="block h-auto w-full transition-transform duration-500 hover:scale-[1.03]"
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          </div>
        ))}
      </div>
      <!-- Tablet: 2 columns -->
      <div class="hidden gap-3 sm:flex lg:hidden">
        {galleryCols2.map((col) => (
          <div class="flex flex-1 flex-col gap-3">
            {col.map(({ img, i }) => (
              <div class="overflow-hidden">
                <img
                  src={img}
                  alt={`${title}, Photo ${i + 1}`}
                  class="block h-auto w-full transition-transform duration-500 hover:scale-[1.03]"
                  loading={i < 2 ? 'eager' : 'lazy'}
                />
              </div>
            ))}
          </div>
        ))}
      </div>
      <!-- Desktop: 3 columns -->
      <div class="hidden gap-3 lg:flex">
        {galleryCols3.map((col) => (
          <div class="flex flex-1 flex-col gap-3">
            {col.map(({ img, i }) => (
              <div class="overflow-hidden">
                <img
                  src={img}
                  alt={`${title}, Photo ${i + 1}`}
                  class="block h-auto w-full transition-transform duration-500 hover:scale-[1.03]"
                  loading={i < 3 ? 'eager' : 'lazy'}
                />
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- From the Journal (project-linked posts) -->
  {journalPosts.length > 0 && (
    <section class="bg-cream-dark px-6 py-20 md:px-12 md:py-28">
      <div class="mx-auto max-w-7xl">
        <div class="mb-12">
          <p class="mb-3 text-xs font-sans font-medium uppercase tracking-[0.15em] text-olive">
            From the Journal
          </p>
          <h2 class="font-serif text-3xl font-light text-charcoal md:text-4xl">
            Behind the {title}
          </h2>
        </div>
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {journalPosts.map((post) => <JournalCard post={post} />)}
        </div>
      </div>
    </section>
  )}

  <!-- Prev / Next Navigation -->
  {(prev || next) && (
    <section class="border-t border-warm-gray px-6 py-16 md:px-12">
      <div class="mx-auto flex max-w-7xl items-stretch justify-between gap-8">
        {prev ? (
          <a href={`/portfolio/${prev.id}`} class="group flex-1">
            <p class="mb-2 text-xs font-sans font-medium uppercase tracking-[0.15em] text-charcoal-light">
              Previous Project
            </p>
            <p class="font-serif text-xl font-light text-charcoal transition-colors group-hover:text-olive md:text-2xl">
              {prev.data.title}
            </p>
          </a>
        ) : <div class="flex-1" />}
        {next ? (
          <a href={`/portfolio/${next.id}`} class="group flex-1 text-right">
            <p class="mb-2 text-xs font-sans font-medium uppercase tracking-[0.15em] text-charcoal-light">
              Next Project
            </p>
            <p class="font-serif text-xl font-light text-charcoal transition-colors group-hover:text-olive md:text-2xl">
              {next.data.title}
            </p>
          </a>
        ) : <div class="flex-1" />}
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-olive px-6 py-20 md:px-12 md:py-28">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-4 font-serif text-4xl font-light text-white md:text-5xl">
        Love This Project?
      </h2>
      <p class="mb-8 text-lg text-white/80">
        Let's create something just as beautiful for your home.
      </p>
      <a
        href="/contact"
        class="inline-block border-2 border-white px-8 py-3.5 text-xs font-sans font-medium uppercase tracking-[0.2em] text-white transition-all hover:bg-white hover:text-olive"
      >
        Book a Consultation
      </a>
    </div>
  </section>
</BaseLayout>
