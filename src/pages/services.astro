---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    title: 'Design Consultations',
    description: 'Expert guidance for your design journey, available virtually or in-person.',
    details: 'Get professional advice on color schemes, materials, furniture selection, and overall design direction.',
    image: '/images/piano-room-services.jpg',
  },
  {
    title: 'Space Planning & Styling',
    description: 'Optimize layouts and enhance functionality with expert space planning.',
    details: 'From furniture arrangement to decor selection, we maximize your space\'s potential while maintaining visual harmony.',
    image: '/images/elegant-dining-kitchen-services.jpg',
  },
  {
    title: 'Renovation & Remodeling',
    description: 'Breathe new life into existing spaces with thoughtful transformations.',
    details: 'Our renovation expertise combines structural optimization with aesthetic refinement for stunning before-and-after results.',
    image: '/images/warm-kitchen.jpg',
  },
  {
    title: 'Holiday & Front Porch Decor',
    description: 'Full-service curation and installation of seasonal and year-round decor.',
    details: 'We design and style welcoming holiday spaces, from festive home decor to thoughtfully arranged front porch elements.',
    image: '/images/cozy-haven-basement.jpg',
  },
];

---

<BaseLayout title="Services | Revive Studios">
  <!-- Page Header -->
  <section class="px-6 pb-8 pt-28 md:px-12 md:pb-12 md:pt-36">
    <div class="mx-auto max-w-7xl">
      <h1 class="mb-6 font-serif text-5xl font-light text-charcoal md:text-6xl">
        Our Services
      </h1>
      <p class="max-w-2xl text-lg leading-relaxed text-charcoal-light">
        We offer comprehensive interior design services tailored to your unique
        needs. From initial concept to final installation, we guide you through
        every step of creating spaces that inspire.
      </p>
    </div>
  </section>

  <!-- Services -->
  <section class="px-6 pb-20 md:px-12 md:pb-28">
    <div class="mx-auto max-w-7xl space-y-20 md:space-y-28">
      {services.map((service, i) => (
        <div class:list={[
          'grid items-center gap-12 md:grid-cols-2 md:gap-16',
          i % 2 === 1 && 'md:[&>*:first-child]:order-2',
        ]}>
          <div class="overflow-hidden">
            <img
              src={service.image}
              alt={service.title}
              class="aspect-[4/3] h-auto w-full object-cover"
              loading="lazy"
            />
          </div>
          <div>
            <h2 class="mb-4 font-serif text-3xl font-light text-charcoal md:text-4xl">
              {service.title}
            </h2>
            <p class="mb-4 text-lg leading-relaxed text-charcoal-light">
              {service.description}
            </p>
            <p class="text-base leading-relaxed text-charcoal-light">
              {service.details}
            </p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Pricing -->
  <section class="px-6 py-20 md:px-12 md:py-28">
    <div class="mx-auto max-w-7xl">
      <!-- Header -->
      <div class="mb-16 text-center">
        <h2 class="mb-4 font-serif text-4xl font-light text-charcoal md:text-5xl">
          Our Pricing
        </h2>
        <p class="mx-auto max-w-2xl text-lg leading-relaxed text-charcoal-light">
          Every project is unique, which is why we provide individualized proposals
          tailored to the specific scope and complexity of each engagement.
        </p>
      </div>

      <!-- Benchmark Callout -->
      <div class="mx-auto mb-16 max-w-3xl border-y border-warm-gray py-12 text-center">
        <p class="mb-3 text-sm uppercase tracking-[0.15em] text-charcoal-light">
          Typical Design Fee Range
        </p>
        <p class="mb-3 font-serif text-6xl font-light text-olive md:text-7xl">
          3% – 5%
        </p>
        <p class="text-base leading-relaxed text-charcoal-light">
          of total project cost, reflecting the level of customization
          and detail your design requires
        </p>
      </div>

      <!-- Value Highlights -->
      <div class="mb-16 grid gap-10 md:grid-cols-2 md:gap-8">
        <div class="border-l-2 border-warm-gray pl-6">
          <h3 class="mb-3 font-serif text-xl font-light text-charcoal">
            Creative Solutions
          </h3>
          <p class="text-sm leading-relaxed text-charcoal-light">
            Our team regularly identifies value-engineering opportunities that
            reduce overall project costs, frequently offsetting our fees
            in the process.
          </p>
        </div>
        <div class="border-l-2 border-warm-gray pl-6">
          <h3 class="mb-3 font-serif text-xl font-light text-charcoal">
            A Smart Investment
          </h3>
          <p class="text-sm leading-relaxed text-charcoal-light">
            A skilled interior designer is often one of the best investments you
            can make in a remodel or build, making your project more cost-effective
            and efficient from start to finish.
          </p>
        </div>
      </div>

      <!-- Closing -->
      <p class="mx-auto max-w-2xl text-center text-lg italic leading-relaxed text-charcoal-light">
        Working with Revive Studios makes your project smarter, more
        cost-effective, and more efficient from start to finish.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-olive px-6 py-20 md:px-12 md:py-28">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-4 font-serif text-4xl font-light text-white md:text-5xl">
        Ready to Start Your Project?
      </h2>
      <p class="mb-8 text-lg text-white/80">
        Let's discuss how we can transform your space.
      </p>
      <a
        href="/contact"
        class="inline-block border-2 border-white px-8 py-3.5 text-xs font-sans font-medium uppercase tracking-[0.2em] text-white transition-all hover:bg-white hover:text-olive"
      >
        Book a Consultation
      </a>
    </div>
  </section>
</BaseLayout>
