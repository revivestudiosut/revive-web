---
import BaseLayout from '../layouts/BaseLayout.astro';

const team = [
  {
    name: 'Megan Davies',
    role: 'Founder & Lead Designer',
    image: '/images/megan-photo.jpg',
    bio: 'Megan specializes in space planning and contractor coordination, bringing thoughtful expertise and a collaborative spirit to every project, ensuring each home comes together beautifully and smoothly.',
  },
  {
    name: 'Cassidy Johnson',
    role: 'Founder & Lead Designer',
    image: '/images/cassidy-photo.jpg',
    bio: 'Cassidy specializes in material and furniture selection as well as innovative space planning, bringing creativity and a personal touch to every project to make each home feel cohesive and welcoming.',
  },
];

const process = [
  {
    number: '01',
    title: 'Discovery & Consultation',
    description: 'We begin by understanding your vision, lifestyle, and functional needs through in-depth conversations and site analysis.',
  },
  {
    number: '02',
    title: 'Concept Development',
    description: 'Our team creates mood boards, color palettes, and preliminary layouts that capture your desired aesthetic.',
  },
  {
    number: '03',
    title: 'Design Refinement',
    description: 'We refine the concept with detailed drawings, material selections, and 3D visualizations for your approval.',
  },
  {
    number: '04',
    title: 'Implementation',
    description: 'From procurement to installation, we manage every detail to bring your vision to life seamlessly.',
  },
];
---

<BaseLayout title="About — Revive Studios">
  <!-- Page Header -->
  <section class="px-6 pb-16 pt-28 md:px-12 md:pb-20 md:pt-36">
    <div class="mx-auto max-w-7xl text-center">
      <h1 class="font-serif text-5xl font-light text-charcoal md:text-6xl">
        About Us
      </h1>
    </div>
  </section>

  <!-- Our Story -->
  <section class="px-6 pb-20 md:px-12 md:pb-28">
    <div class="mx-auto grid max-w-7xl items-center gap-12 md:grid-cols-2 md:gap-20">
      <div class="space-y-6 text-lg leading-relaxed text-charcoal-light">
        <p>
          Revive Studios was built on a shared passion for creating homes that
          feel effortlessly beautiful, deeply personal, and designed for real
          life. With years of interior design experience and formal training,
          our team brings both expertise and heart to every project.
        </p>
        <p>
          As a full-service design studio, we guide you through every step of
          the process. From the early plans and material selections, to the
          final styling touches — making the process simple, seamless, and
          enjoyable.
        </p>
        <p>
          Our mission is to craft homes that reflect your family's story and
          lifestyle — spaces you'll love, live in, and make memories in for
          years to come. Our commitment remains unchanged: creating interiors
          that feel both effortless and extraordinary.
        </p>
      </div>
      <div class="overflow-hidden">
        <img
          src="/images/elegant-dining-kitchen.jpg"
          alt="Open concept kitchen designed by Revive Studios"
          class="h-auto w-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Meet the Team -->
  <section class="bg-cream-dark px-6 py-20 md:px-12 md:py-28">
    <div class="mx-auto max-w-7xl">
      <div class="mb-16 text-center">
        <h2 class="mb-4 font-serif text-4xl font-light text-charcoal md:text-5xl">
          Meet the Team
        </h2>
        <p class="text-charcoal-light">
          Passionate designers dedicated to bringing your vision to life
        </p>
      </div>
      <div class="mx-auto grid max-w-4xl gap-12 md:grid-cols-2 md:gap-16">
        {team.map((member) => (
          <div class="text-center">
            <div class="mx-auto mb-6 aspect-[3/4] w-full max-w-sm overflow-hidden">
              <img
                src={member.image}
                alt={member.name}
                class="h-full w-full object-cover object-top"
                loading="lazy"
              />
            </div>
            <h3 class="mb-1 font-serif text-2xl font-light text-charcoal">
              {member.name}
            </h3>
            <p class="mb-4 text-sm uppercase tracking-[0.1em] text-olive">
              {member.role}
            </p>
            <p class="text-sm leading-relaxed text-charcoal-light">
              {member.bio}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Process -->
  <section class="px-6 py-20 md:px-12 md:py-28">
    <div class="mx-auto max-w-7xl">
      <div class="mb-16 text-center">
        <h2 class="mb-4 font-serif text-4xl font-light text-charcoal md:text-5xl">
          Our Process
        </h2>
        <p class="text-charcoal-light">
          A collaborative journey from concept to completion
        </p>
      </div>
      <div class="grid gap-12 md:grid-cols-4 md:gap-8">
        {process.map((step) => (
          <div>
            <span class="mb-4 block font-serif text-5xl font-light text-olive/30">
              {step.number}
            </span>
            <h3 class="mb-3 font-serif text-xl font-light text-charcoal">
              {step.title}
            </h3>
            <p class="text-sm leading-relaxed text-charcoal-light">
              {step.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-olive px-6 py-20 md:px-12 md:py-28">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-4 font-serif text-4xl font-light text-white md:text-5xl">
        Let's Create Together
      </h2>
      <p class="mb-8 text-lg text-white/80">
        Ready to start your design journey?
      </p>
      <a
        href="/contact"
        class="inline-block border-2 border-white px-8 py-3.5 text-xs font-sans font-medium uppercase tracking-[0.2em] text-white transition-all hover:bg-white hover:text-olive"
      >
        Book a Consultation
      </a>
    </div>
  </section>
</BaseLayout>
