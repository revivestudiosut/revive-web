# direnv configuration — auto-loads environment variables
# Install: brew install direnv
# Shell hook: eval "$(direnv hook zsh)" in ~/.zshrc
# Activate: direnv allow

# Load shared defaults
dotenv .env

# Load environment-specific overrides (contains secrets)
# Set DEPLOY_ENV before entering the directory, or defaults to dev
export DEPLOY_ENV="${DEPLOY_ENV:-dev}"
dotenv_if_exists ".env.${DEPLOY_ENV}"
